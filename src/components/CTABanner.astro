---
import { SIGNUP_URL, CTA_PRIMARY, CTA_SECONDARY } from '../data/site';

interface Props {
  title?: string;
  note?: string;
}
const {
  title = 'Put your next route on MLogTech.',
  note = `Free trial, no card required. Or see it against your own data first.`,
} = Astro.props;
---

<!-- Deliberate fixed-dark band: the one drenched moment per page, identical
     in light and dark. Colors come from the theme-independent fixed-* tokens. -->
<section class="section bg-[color:var(--fixed-dark)]">
  <div class="wrap text-center">
    <h2 class="h2 reveal mx-auto max-w-[24ch] text-[color:var(--fixed-ink)]">{title}</h2>
    <p class="reveal mx-auto mt-4 max-w-[52ch] text-[color:var(--fixed-body)]">{note}</p>
    <div class="reveal mt-8 flex flex-wrap justify-center gap-3">
      <a href={SIGNUP_URL} class="btn btn-primary">{CTA_PRIMARY}</a>
      <a
        href="/demo/"
        class="btn btn-ghost border-[color:var(--fixed-hair)] text-[color:var(--fixed-ink)] hover:border-accent"
        >{CTA_SECONDARY}</a
      >
    </div>
  </div>
</section>
