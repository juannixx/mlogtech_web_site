---
// Single real production reference, framed honestly as one reference rather than
// a "partners" wall (we have one authorized logo). Add more logos or a quote
// here when they are authorized (SPEC-03 §10).
---

<section class="border-y border-hair bg-surface py-7">
  <div class="wrap flex flex-wrap items-center justify-center gap-x-5 gap-y-3">
    <span class="text-[0.95rem] text-muted">In production with</span>
    <img
      src="/images/molina-express.png"
      alt="Molina Express"
      width="140"
      height="40"
      loading="lazy"
      class="h-9 w-auto opacity-80 grayscale"
    />
  </div>
</section>
