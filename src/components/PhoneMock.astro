---
// Stylized driver-app mockup (SVG, token-driven, theme-aware).
// [PENDENTE SPEC-03 §6: replace with real app screenshots when available.]
---

<figure
  class="mx-auto w-full max-w-[280px]"
  role="img"
  aria-label="Illustrative preview of the MLogTech driver app: a delivery being completed with signature and photo proof"
>
  <svg viewBox="0 0 280 560" fill="none" aria-hidden="true" class="block w-full">
    <rect x="4" y="4" width="272" height="552" rx="36" fill="var(--surface)" stroke="var(--hair-strong)" stroke-width="2"></rect>
    <rect x="104" y="18" width="72" height="10" rx="5" fill="var(--hair)"></rect>
    <!-- header -->
    <rect x="24" y="48" width="160" height="14" rx="4" fill="var(--hair-strong)"></rect>
    <rect x="24" y="72" width="100" height="9" rx="3" fill="var(--hair)"></rect>
    <!-- stop card -->
    <rect x="20" y="100" width="240" height="92" rx="12" fill="var(--surface-2)"></rect>
    <circle cx="46" cy="132" r="11" fill="var(--accent)"></circle>
    <text x="46" y="136" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="var(--accent-ink)">3</text>
    <rect x="68" y="118" width="130" height="11" rx="3" fill="var(--hair-strong)"></rect>
    <rect x="68" y="138" width="90" height="8" rx="3" fill="var(--hair)"></rect>
    <rect x="68" y="160" width="150" height="8" rx="3" fill="var(--hair)"></rect>
    <!-- signature area -->
    <rect x="20" y="212" width="240" height="150" rx="12" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect x="34" y="226" width="80" height="8" rx="3" fill="var(--hair)"></rect>
    <path
      d="M50 320 C 70 280, 90 330, 110 300 S 150 270, 170 305 S 210 320, 228 292"
      stroke="var(--ink)"
      stroke-width="2.5"
      stroke-linecap="round"></path>
    <!-- photo + scan chips -->
    <rect x="20" y="378" width="115" height="64" rx="12" fill="var(--surface-2)"></rect>
    <rect x="36" y="396" width="28" height="28" rx="6" stroke="var(--accent-text)" stroke-width="2.5" fill="none"></rect>
    <rect x="74" y="400" width="48" height="8" rx="3" fill="var(--hair-strong)"></rect>
    <rect x="145" y="378" width="115" height="64" rx="12" fill="var(--surface-2)"></rect>
    <path d="M162 396v28M170 396v28M180 396v28M186 396v28M196 396v28M204 396v28" stroke="var(--ink)" stroke-width="2.5"></path>
    <rect x="214" y="400" width="34" height="8" rx="3" fill="var(--hair-strong)"></rect>
    <!-- complete button -->
    <rect x="20" y="462" width="240" height="52" rx="12" fill="var(--accent)"></rect>
    <rect x="92" y="482" width="96" height="12" rx="4" fill="var(--accent-ink)" opacity="0.85"></rect>
  </svg>
</figure>
