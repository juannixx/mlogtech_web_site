---
import { SUPPORT_EMAIL, SALES_EMAIL, OFFICES, CTA_SECONDARY } from '../data/site';
import { solutions, solutionHref } from '../data/solutions';

const year = new Date().getFullYear();
---

<footer class="border-t border-hair bg-surface-2">
  <div class="wrap py-14">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1fr]">
      <div>
        <span class="text-[1.05rem] font-extrabold tracking-wide text-ink">MLOGTECH</span>
        <p class="mt-3 max-w-[36ch] text-[0.94rem]">
          Delivery management software with electronic proof of delivery, live tracking and route
          optimization.
        </p>
        <p class="mt-3 text-[0.9rem] text-muted">{OFFICES.join(' | ')}</p>
      </div>
      <nav aria-label="Product">
        <h4 class="mb-3 text-[0.9rem] font-bold text-ink">Product</h4>
        <ul class="space-y-2 text-[0.95rem]">
          <li><a class="hover:text-ink" href="/features/">Features</a></li>
          <li><a class="hover:text-ink" href="/pricing/">Pricing</a></li>
          <li><a class="hover:text-ink" href="/demo/">{CTA_SECONDARY}</a></li>
          <li><a class="hover:text-ink" href="/faq/">FAQ</a></li>
          <li><a class="hover:text-ink" href="/security/">Security</a></li>
        </ul>
      </nav>
      <nav aria-label="Solutions">
        <h4 class="mb-3 text-[0.9rem] font-bold text-ink">Solutions</h4>
        <ul class="space-y-2 text-[0.95rem]">
          {
            solutions.map((s) => (
              <li>
                <a class="hover:text-ink" href={solutionHref(s)}>
                  {s.nav}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <nav aria-label="Company">
        <h4 class="mb-3 text-[0.9rem] font-bold text-ink">Company</h4>
        <ul class="space-y-2 text-[0.95rem]">
          <li><a class="hover:text-ink" href="/contact/">Contact</a></li>
          <li><a class="hover:text-ink" href={`mailto:${SALES_EMAIL}`}>{SALES_EMAIL}</a></li>
          <li><a class="hover:text-ink" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a></li>
        </ul>
      </nav>
    </div>

    <div
      class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-hair pt-6 text-[0.86rem]"
    >
      <span>&copy; {year} MLogTech. All rights reserved.</span>
      <!-- TODO fase 1 restante: Terms, Privacy, Cookies pages (SPEC-01 legal) -->
      <button
        id="theme-toggle"
        class="flex items-center gap-2 rounded-md border border-hair-strong px-3 py-1.5 text-[0.86rem] text-ink"
        aria-pressed="false"
      >
        <span aria-hidden="true" class="theme-dot inline-block h-2.5 w-2.5 rounded-full bg-accent"
        ></span>
        <span class="theme-label">Dark mode</span>
      </button>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    var label = btn.querySelector('.theme-label');
    function current() {
      var attr = document.documentElement.getAttribute('data-theme');
      if (attr) return attr;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    function paint() {
      var dark = current() === 'dark';
      label.textContent = dark ? 'Light mode' : 'Dark mode';
      btn.setAttribute('aria-pressed', String(dark));
    }
    btn.addEventListener('click', function () {
      var next = current() === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
      paint();
    });
    paint();
  })();
</script>
