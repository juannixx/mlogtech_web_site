---
// Stylized product mockup (SVG, token-driven, theme-aware).
// [PENDENTE SPEC-03 §6: replace with real dashboard screenshots when available.]
---

<figure
  class="overflow-hidden rounded-[var(--r-lg)] border border-hair bg-surface shadow-[var(--shadow-lg)]"
  role="img"
  aria-label="Illustrative preview of the MLogTech dispatch dashboard: an optimized route on a map with delivery stops and a live delivery list"
>
  <svg viewBox="0 0 720 460" fill="none" aria-hidden="true" class="block w-full">
    <!-- top bar -->
    <rect x="0" y="0" width="720" height="44" fill="var(--surface-2)"></rect>
    <circle cx="22" cy="22" r="5" fill="var(--hair-strong)"></circle>
    <circle cx="40" cy="22" r="5" fill="var(--hair-strong)"></circle>
    <rect x="64" y="15" width="130" height="14" rx="4" fill="var(--hair)"></rect>
    <rect x="580" y="12" width="118" height="20" rx="6" fill="var(--accent)"></rect>
    <!-- sidebar list -->
    <rect x="0" y="44" width="236" height="416" fill="var(--surface)"></rect>
    <line x1="236" y1="44" x2="236" y2="460" stroke="var(--hair)"></line>
    {
      [0, 1, 2, 3, 4, 5].map((i) => (
        <g>
          <rect x="16" y={64 + i * 64} width="204" height="50" rx="8" fill={i === 1 ? 'var(--surface-2)' : 'transparent'} stroke="var(--hair)" />
          <circle cx="38" cy={89 + i * 64} r="9" fill={i < 2 ? 'var(--accent)' : 'var(--hair-strong)'} />
          <rect x="58" y={78 + i * 64} width="110" height="9" rx="3" fill="var(--hair-strong)" />
          <rect x="58" y={94 + i * 64} width="70" height="7" rx="3" fill="var(--hair)" />
          <rect x="180" y={82 + i * 64} width="30" height="12" rx="4" fill={i < 2 ? 'var(--accent)' : 'var(--hair)'} opacity={i < 2 ? '0.35' : '1'} />
        </g>
      ))
    }
    <!-- map area -->
    <rect x="236" y="44" width="484" height="416" fill="var(--surface-2)"></rect>
    <g stroke="var(--hair)" stroke-width="1">
      <path d="M280 44v416M360 44v416M460 44v416M560 44v416M660 44v416"></path>
      <path d="M236 120h484M236 210h484M236 300h484M236 390h484"></path>
    </g>
    <!-- route -->
    <path
      d="M290 400 C 330 340, 300 300, 370 280 S 470 260, 480 200 S 560 140, 630 110"
      stroke="var(--accent)"
      stroke-width="3.5"
      stroke-linecap="round"
      stroke-dasharray="1 0"></path>
    {
      [
        [290, 400],
        [370, 280],
        [480, 200],
        [630, 110],
      ].map(([x, y], i) => (
        <g>
          <circle cx={x} cy={y} r="12" fill="var(--surface)" stroke="var(--accent)" stroke-width="3" />
          <text
            x={x}
            y={y + 4}
            text-anchor="middle"
            font-family="ui-monospace, Menlo, monospace"
            font-size="11"
            font-weight="600"
            fill="var(--ink)"
          >
            {i + 1}
          </text>
        </g>
      ))
    }
    <!-- eta chip -->
    <rect x="500" y="330" width="180" height="54" rx="10" fill="var(--surface)" stroke="var(--hair-strong)"></rect>
    <circle cx="524" cy="357" r="8" fill="var(--ok)"></circle>
    <rect x="544" y="342" width="100" height="10" rx="3" fill="var(--hair-strong)"></rect>
    <rect x="544" y="360" width="70" height="8" rx="3" fill="var(--hair)"></rect>
  </svg>
</figure>
