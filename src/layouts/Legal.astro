---
import Base from './Base.astro';

// Legal drafts carry a visible review notice until sign-off.
// Regra interna: documento sujeito à revisão do advogado responsável.
// Remove the notice (and this comment) only after legal review.

interface Props {
  title: string;
  description: string;
  h1: string;
  updated: string;
}
const { title, description, h1, updated } = Astro.props;
---

<Base title={title} description={description}>
  <section class="section">
    <div class="wrap max-w-[760px]">
      <p
        class="mb-8 inline-block rounded-md border border-hair-strong px-3 py-1.5 text-[0.85rem] font-semibold text-muted"
      >
        Draft: subject to review by the responsible solicitor before publication.
      </p>
      <h1 class="display max-w-[16ch]">{h1}</h1>
      <p class="mt-3 text-[0.9rem] text-muted">Last updated: {updated}</p>
      <div class="legal-prose mt-10">
        <slot />
      </div>
    </div>
  </section>
</Base>

<style>
  .legal-prose :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.2rem;
  }
  .legal-prose :global(p),
  .legal-prose :global(li) {
    margin-top: 0.9rem;
    font-size: 1rem;
  }
  .legal-prose :global(ul) {
    padding-left: 1.3rem;
    list-style: disc;
  }
  .legal-prose :global(table) {
    margin-top: 1rem;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .legal-prose :global(th),
  .legal-prose :global(td) {
    border: 1px solid var(--hair);
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .legal-prose :global(th) {
    color: var(--ink);
    background: var(--surface-2);
  }
</style>
