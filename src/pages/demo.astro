---
import Base from '../layouts/Base.astro';
import { SALES_EMAIL, VIDEO_PLATFORM_DEMO, VIDEO_DRIVER_DEMO } from '../data/site';

// Form delivery: composes an email to sales until the CRM endpoint exists.
// [PENDENTE SPEC-04 §4/§5: endpoint HubSpot + ferramenta de agendamento]
---

<Base
  title="Book a demo | See MLogTech against your own operation | MLogTech"
  description="Book a 30-minute demo of MLogTech: route optimization, driver app and electronic proof of delivery, walked through against your own delivery operation."
>
  <section class="section">
    <div class="wrap grid gap-14 lg:grid-cols-[1.1fr_1fr]">
      <div class="reveal">
        <h1 class="display max-w-[18ch]">See MLogTech working with your data.</h1>
        <p class="lead mt-4">A 30-minute call, on your operation, not a slide deck.</p>
        <ul class="mt-8 space-y-4 text-[1.02rem]">
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            We map how your orders arrive and how routes are planned today.
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            You watch a route go from import to optimized to dispatched, live.
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            We show the driver app capturing a POD and where the record lands.
          </li>
        </ul>

        <div class="mt-12 space-y-8">
          <div>
            <h2 class="h3">Prefer to watch first?</h2>
            <p class="mt-2 text-[0.95rem] text-muted">
              Two recorded walkthroughs: the dispatch platform and the driver app.
            </p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2">
            <button
              class="video-slot group relative aspect-video overflow-hidden rounded-[var(--r)] border border-hair bg-surface-2 text-left"
              data-src={VIDEO_PLATFORM_DEMO}
              aria-label="Play the platform overview video"
            >
              <img
                src="/images/warehouse-aisle.jpg"
                alt=""
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover opacity-70 transition-opacity group-hover:opacity-90"
              />
              <span
                class="absolute inset-0 m-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent"
              >
                <svg width="18" height="20" viewBox="0 0 18 20" fill="none" aria-hidden="true">
                  <path d="M2 1.5v17l14-8.5L2 1.5z" fill="var(--accent-ink)"></path>
                </svg>
              </span>
              <span
                class="absolute bottom-0 w-full bg-[color:var(--fixed-dark)]/85 px-4 py-2.5 text-[0.9rem] font-semibold text-[color:var(--fixed-ink)]"
                >Platform overview</span
              >
            </button>
            <button
              class="video-slot group relative aspect-video overflow-hidden rounded-[var(--r)] border border-hair bg-surface-2 text-left"
              data-src={VIDEO_DRIVER_DEMO}
              aria-label="Play the driver app demo video"
            >
              <img
                src="/images/driver-clipboard.jpg"
                alt=""
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover opacity-70 transition-opacity group-hover:opacity-90"
              />
              <span
                class="absolute inset-0 m-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent"
              >
                <svg width="18" height="20" viewBox="0 0 18 20" fill="none" aria-hidden="true">
                  <path d="M2 1.5v17l14-8.5L2 1.5z" fill="var(--accent-ink)"></path>
                </svg>
              </span>
              <span
                class="absolute bottom-0 w-full bg-[color:var(--fixed-dark)]/85 px-4 py-2.5 text-[0.9rem] font-semibold text-[color:var(--fixed-ink)]"
                >Driver app demo</span
              >
            </button>
          </div>
        </div>
      </div>

      <div class="reveal">
        <form
          id="demo-form"
          class="rounded-[var(--r-lg)] border border-hair bg-surface p-8 shadow-[var(--shadow-md)]"
        >
          <h2 class="h3">Book your demo</h2>
          <p class="mt-2 text-[0.95rem] text-muted">
            Takes a minute. We reply within one working day with a link to book your slot.
          </p>
          <p class="mt-1 text-[0.85rem] text-muted">All fields are required unless marked optional.</p>
          <div class="mt-6 space-y-4">
            <div class="field">
              <label for="d-name">Name</label>
              <input id="d-name" name="name" type="text" autocomplete="name" required aria-describedby="d-name-error" />
              <p class="error" id="d-name-error" role="alert"></p>
            </div>
            <div class="field">
              <label for="d-email">Work email</label>
              <input id="d-email" name="email" type="email" autocomplete="email" required aria-describedby="d-email-error" />
              <p class="error" id="d-email-error" role="alert"></p>
            </div>
            <div class="field">
              <label for="d-phone">Phone <span class="font-normal text-muted">(optional)</span></label>
              <input id="d-phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div class="field">
              <label for="d-volume">Deliveries per month</label>
              <select id="d-volume" name="volume">
                <option>Up to 500</option>
                <option>500 to 2,000</option>
                <option>2,000 to 8,000</option>
                <option>More than 8,000</option>
              </select>
            </div>
            <!-- honeypot -->
            <div class="hidden" aria-hidden="true">
              <label for="d-company-site">Company site</label>
              <input id="d-company-site" name="companysite" type="text" tabindex="-1" autocomplete="off" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary mt-6 w-full">Book a demo</button>
          <p id="demo-status" class="mt-3 min-h-[1.4em] text-[0.95rem] text-accent-text" role="status" aria-live="polite"></p>
          <p class="mt-2 text-[0.9rem] text-muted">
            Prefer email? <a class="textlink" href={`mailto:${SALES_EMAIL}`}>{SALES_EMAIL}</a>
          </p>
        </form>

        <!-- Success state: shown after submit. First-success + clear next steps. -->
        <div
          id="demo-success"
          class="hidden rounded-[var(--r-lg)] border border-hair bg-surface p-8 shadow-[var(--shadow-md)]"
          role="status"
          aria-live="polite"
        >
          <span
            class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-accent"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M4 10.5L8 14.5L16 5.5"
                stroke="var(--accent-ink)"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
          <h2 class="h3 mt-4">Request ready, <span id="ds-name">there</span>.</h2>
          <p class="mt-2 text-[1.02rem]">
            We have opened your email app to send it. Once it lands, we reply within one working
            day at <span id="ds-email" class="font-semibold text-ink">your inbox</span> with a link
            to book your slot.
          </p>
          <ol class="mt-6 space-y-3 text-[0.95rem]">
            <li class="flex gap-3">
              <span class="data mt-0.5 text-accent-text">1</span>
              We reply with a link to pick a 30-minute slot.
            </li>
            <li class="flex gap-3">
              <span class="data mt-0.5 text-accent-text">2</span>
              On the call we run a route on your own data, end to end.
            </li>
            <li class="flex gap-3">
              <span class="data mt-0.5 text-accent-text">3</span>
              You leave with a quote priced against your fleet.
            </li>
          </ol>
          <p class="mt-6 text-[0.9rem] text-muted">
            Nothing opened? Email <a class="textlink" href={`mailto:${SALES_EMAIL}`}>{SALES_EMAIL}</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<script is:inline define:vars={{ SALES_EMAIL }}>
  (function () {
    // Click-to-load video embeds (no YouTube JS until interaction, SPEC-04 §2).
    document.querySelectorAll('.video-slot').forEach(function (slot) {
      slot.addEventListener('click', function () {
        var iframe = document.createElement('iframe');
        iframe.src = slot.dataset.src + '?autoplay=1';
        iframe.title = slot.getAttribute('aria-label') || 'Demo video';
        iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.className = 'absolute inset-0 h-full w-full';
        slot.replaceChildren(iframe);
      });
    });

    // Demo form: mailto composition until the CRM endpoint exists.
    var form = document.getElementById('demo-form');
    var success = document.getElementById('demo-success');
    if (!form || !success) return;

    // Inline validation: show errors next to the field, not as native bubbles.
    // Without JS the native required/type validation still applies.
    form.noValidate = true;
    var messages = {
      'd-name': 'Enter your name.',
      'd-email': 'Enter your work email.',
    };
    var fields = Object.keys(messages).map(function (id) { return form.querySelector('#' + id); });
    function messageFor(input) {
      var v = input.validity;
      if (v.valid) return '';
      if (v.typeMismatch && input.type === 'email') return 'Enter a valid email address, like name@company.com.';
      if (v.valueMissing) return messages[input.id];
      return 'Please check this field.';
    }
    function showError(input, msg) {
      var box = document.getElementById(input.id + '-error');
      input.setAttribute('aria-invalid', msg ? 'true' : 'false');
      if (box) box.textContent = msg || '';
    }
    fields.forEach(function (input) {
      input.addEventListener('input', function () {
        if (input.getAttribute('aria-invalid') === 'true') showError(input, messageFor(input));
      });
    });
    function firstInvalid() {
      var first = null;
      fields.forEach(function (input) {
        var msg = messageFor(input);
        showError(input, msg);
        if (msg && !first) first = input;
      });
      return first;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (form.querySelector('[name="companysite"]').value) return; // honeypot
      var invalid = firstInvalid();
      if (invalid) {
        invalid.focus();
        return;
      }
      var name = form.querySelector('#d-name').value.trim();
      var email = form.querySelector('#d-email').value.trim();
      var phone = form.querySelector('#d-phone').value.trim();
      var volume = form.querySelector('#d-volume').value;
      var body =
        'Name: ' + name + '\nWork email: ' + email + '\nPhone: ' + (phone || 'not provided') +
        '\nDeliveries per month: ' + volume + '\n\nPlease send me a link to schedule a demo.';
      window.location.href =
        'mailto:' + SALES_EMAIL +
        '?subject=' + encodeURIComponent('Demo request: ' + name) +
        '&body=' + encodeURIComponent(body);
      // Swap to the success state with the user's own details.
      var firstName = name.split(' ')[0] || 'there';
      document.getElementById('ds-name').textContent = firstName;
      document.getElementById('ds-email').textContent = email;
      form.classList.add('hidden');
      success.classList.remove('hidden');
      success.focus && success.setAttribute('tabindex', '-1');
      success.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    });
  })();
</script>
