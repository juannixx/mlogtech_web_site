---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found | MLogTech"
  description="The page you were looking for does not exist. Find solutions, features and pricing from here."
>
  <section class="section">
    <div class="wrap max-w-[640px] text-center">
      <p class="data text-accent-text">404</p>
      <h1 class="h2 mt-3">That route does not exist.</h1>
      <p class="mt-4">
        The address may have changed. These are the most useful places to restart from:
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn btn-ghost">Home</a>
        <a href="/solutions/" class="btn btn-ghost">Solutions</a>
        <a href="/features/" class="btn btn-ghost">Features</a>
        <a href="/pricing/" class="btn btn-ghost">Pricing</a>
        <a href="/demo/" class="btn btn-primary">Book a demo</a>
      </div>
    </div>
  </section>
</Base>
