---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';
import { SALES_EMAIL } from '../data/site';

// Integrations hub (SPEC-02 §7). Content is now grounded in the product's
// real integration surface (Molina/MLogTech feature catalogue, module 09):
// CSV import, REST import + tracking API, HMAC-signed outbound webhooks, and a
// Zapier app built on those webhooks. Native storefront/ERP connectors are
// genuinely still in rollout, so those stay honest as "in rollout".

// Available today, confirmed shipped.
const availableNow = [
  {
    title: 'Order import',
    body: 'Bring the day’s orders in by spreadsheet or CSV, or push them straight to the manifest-import REST endpoint. Addresses are validated and geocoded on the way in.',
  },
  {
    title: 'Signed webhooks',
    body: 'HMAC-signed events fire as things happen: order created, delivered, failed, and route started or completed. Your systems react in real time, and can verify every payload came from us.',
  },
  {
    title: 'Public tracking API',
    body: 'REST endpoints expose live tracking and delivery status, so you can surface an order’s progress inside your own app or portal.',
  },
];

// Connector categories genuinely still being built.
const rollout = [
  { title: 'E-commerce platforms', body: 'Orders flowing straight from your store checkout to the dispatch board.' },
  { title: 'ERP and order management', body: 'Keep your system of record; deliveries and PODs sync both ways.' },
  { title: 'Marketplaces', body: 'Marketplace orders joining the same routes as everything else you ship.' },
  { title: 'Accounting', body: 'Completed deliveries with proof, ready to bill without re-keying.' },
];
---

<Base
  title="Integrations | Import, webhooks, tracking API | MLogTech"
  description="Get orders into MLogTech and results back out: CSV import, a manifest-import REST API, HMAC-signed webhooks and a public tracking API. Native connectors in rollout."
>
  <section class="section">
    <div class="wrap max-w-[860px]">
      <h1 class="display max-w-[18ch]">Your orders already live somewhere.</h1>
      <p class="lead mt-4">
        Bring them in by import or API, get every event back through signed webhooks, and read
        live tracking straight from ours. Native connectors land on top as the catalog rolls out.
      </p>
    </div>
  </section>

  <section class="pb-16">
    <div class="wrap grid gap-6 md:grid-cols-3">
      {
        availableNow.map((c) => (
          <div class="reveal rounded-[var(--r)] border border-hair bg-surface p-7">
            <span class="data text-[0.75rem] text-accent-text">Available now</span>
            <h2 class="h3 mt-2">{c.title}</h2>
            <p class="mt-2 text-[0.95rem]">{c.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section bg-surface-2">
    <div class="wrap">
      <div class="reveal max-w-[62ch]">
        <h2 class="h2">Automate without waiting for a connector.</h2>
        <p class="lead mt-4">
          The webhooks and REST API are open today, so you can wire MLogTech into the rest of your
          stack now. A Zapier app built on the same webhooks is on the way for no-code automation.
        </p>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          rollout.map((c) => (
            <div class="reveal rounded-[var(--r)] border border-hair bg-surface p-6">
              <span class="data text-[0.75rem] text-muted">In rollout</span>
              <h3 class="h3 mt-2 text-[1.15rem]">{c.title}</h3>
              <p class="mt-2 text-[0.95rem]">{c.body}</p>
            </div>
          ))
        }
        <div
          class="reveal flex flex-col justify-center rounded-[var(--r)] border border-dashed border-hair-strong p-6"
        >
          <h3 class="h3 text-[1.15rem]">Your platform?</h3>
          <p class="mt-2 text-[0.95rem]">
            <a class="textlink" href={`mailto:${SALES_EMAIL}`}>Tell us what you run</a> and we will
            tell you the integration path, honestly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div
      class="wrap grid items-center gap-10 rounded-[var(--r-lg)] border border-hair bg-surface p-10 md:grid-cols-[1.3fr_1fr]"
    >
      <div class="reveal">
        <h2 class="h2">Building it yourself? The API is open.</h2>
        <p class="mt-4 text-[1.02rem]">
          Create orders and import manifests, read live tracking, and subscribe to HMAC-signed
          events (order created, delivered, failed, route started and completed). Bring your
          integration question to a demo and we will walk the endpoints with you.
        </p>
      </div>
      <div class="reveal md:text-right">
        <a href="/demo/" class="btn btn-primary">Book a demo</a>
      </div>
    </div>
  </section>

  <CTABanner />
</Base>
