---
import Base from '../layouts/Base.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';
import { SIGNUP_URL, CTA_PRIMARY } from '../data/site';
import {
  MOCK_PRICING,
  CURRENCY,
  TRIAL_DAYS,
  ANNUAL_DISCOUNT_LABEL,
  driverPlans,
  orderPlans,
  compare,
  billingFaq,
} from '../data/pricing';

// Mock prices must never be indexed: no Product/Offer JSON-LD while MOCK_PRICING.
const showMockBadge = MOCK_PRICING && import.meta.env.DEV;
---

<Base
  title="Pricing | Per driver or per order, no driver minimum | MLogTech"
  description={`Simple delivery management pricing in GBP: per driver or per order, monthly or annual, ${TRIAL_DAYS}-day free trial and no driver minimum.`}
>
  <section class="section pb-8">
    <div class="wrap text-center">
      {
        showMockBadge && (
          <p class="mx-auto mb-6 inline-block rounded-md border border-err px-3 py-1 text-[0.85rem] font-semibold text-err">
            PROVISIONAL PRICING (dev only): Track-POD benchmark, pending sign-off
          </p>
        )
      }
      <h1 class="display mx-auto max-w-[22ch]">Priced to match how you deliver.</h1>
      <p class="lead mx-auto mt-4">
        Per driver or per order, in GBP. No contracts, no driver minimum, cancel any time.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
        <div
          class="inline-flex rounded-[var(--r)] border border-hair-strong p-1"
          role="radiogroup"
          aria-label="Pricing model"
          id="model-toggle"
        >
          <button
            class="rounded-[9px] px-5 py-2 text-[0.95rem] font-semibold"
            role="radio"
            aria-checked="true"
            data-model="driver">Per driver</button
          >
          <button
            class="rounded-[9px] px-5 py-2 text-[0.95rem] font-semibold"
            role="radio"
            aria-checked="false"
            data-model="order">Per order</button
          >
        </div>
        <div
          class="inline-flex items-center gap-3"
          role="radiogroup"
          aria-label="Billing cycle"
          id="cycle-toggle"
        >
          <button
            class="rounded-[9px] px-4 py-2 text-[0.95rem] font-semibold"
            role="radio"
            aria-checked="true"
            data-cycle="annual">Annual ({ANNUAL_DISCOUNT_LABEL})</button
          >
          <button
            class="rounded-[9px] px-4 py-2 text-[0.95rem] font-semibold"
            role="radio"
            aria-checked="false"
            data-cycle="monthly">Monthly</button
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Per driver -->
  <section class="pb-16" id="plans-driver">
    <div class="wrap grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        driverPlans.map((p) => (
          <div
            class:list={[
              'relative flex flex-col rounded-[var(--r)] border bg-surface p-7',
              p.popular ? 'border-accent shadow-[var(--shadow-md)]' : 'border-hair',
            ]}
          >
            {p.popular && (
              <span class="absolute -top-3 left-6 rounded-full bg-accent px-3 py-0.5 text-[0.78rem] font-bold text-accent-ink">
                Most popular
              </span>
            )}
            <h2 class="h3">{p.name}</h2>
            <p class="mt-4 min-h-[64px]">
              {p.monthly === null ? (
                <span class="text-[1.7rem] font-extrabold text-ink">Let's talk</span>
              ) : (
                <>
                  <span class="data price-value text-[2.1rem] font-bold text-ink" data-annual={p.annual} data-monthly={p.monthly}>
                    {CURRENCY}{p.annual}
                  </span>
                  <span class="block text-[0.88rem] text-muted">per driver / month</span>
                </>
              )}
            </p>
            <ul class="mt-4 flex-1 space-y-2.5 text-[0.95rem]">
              {p.highlights.map((h) => (
                <li class="flex gap-2.5">
                  <svg class="mt-1 shrink-0" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2 7.5L5.5 11L12 3.5" stroke="var(--ok)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {h}
                </li>
              ))}
            </ul>
            {p.cta === 'trial' ? (
              <a href={SIGNUP_URL} class:list={['btn mt-6', p.popular ? 'btn-primary' : 'btn-ghost']}>
                {CTA_PRIMARY}
              </a>
            ) : (
              <a href="/demo/" class="btn btn-ghost mt-6">
                Talk to sales
              </a>
            )}
          </div>
        ))
      }
    </div>
  </section>

  <!-- Per order -->
  <section class="hidden pb-16" id="plans-order">
    <div class="wrap grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        orderPlans.map((p) => (
          <div
            class:list={[
              'relative flex flex-col rounded-[var(--r)] border bg-surface p-7',
              p.popular ? 'border-accent shadow-[var(--shadow-md)]' : 'border-hair',
            ]}
          >
            {p.popular && (
              <span class="absolute -top-3 left-6 rounded-full bg-accent px-3 py-0.5 text-[0.78rem] font-bold text-accent-ink">
                Most popular
              </span>
            )}
            <h2 class="h3">Plan {p.name}</h2>
            <p class="mt-4">
              <span class="data text-[2.1rem] font-bold text-ink">
                {CURRENCY}{p.monthly}
              </span>
              <span class="block text-[0.88rem] text-muted">per month</span>
            </p>
            <ul class="mt-4 flex-1 space-y-2.5 text-[0.95rem]">
              <li>{p.orders.toLocaleString('en-GB')} orders / month included</li>
              <li>
                <span class="data">
                  {CURRENCY}{p.perOrder}
                </span>{' '}
                effective cost per order
              </li>
              <li>All Growth features included</li>
              <li>Unlimited drivers</li>
            </ul>
            {p.cta === 'trial' ? (
              <a href={SIGNUP_URL} class:list={['btn mt-6', p.popular ? 'btn-primary' : 'btn-ghost']}>
                {CTA_PRIMARY}
              </a>
            ) : (
              <a href="/demo/" class="btn btn-ghost mt-6">
                Talk to sales
              </a>
            )}
          </div>
        ))
      }
    </div>
  </section>

  <!-- Comparison table -->
  <section class="section bg-surface-2" id="compare">
    <div class="wrap">
      <h2 class="h2 reveal">Compare plans in full.</h2>
      <p class="mt-3 text-muted text-[0.92rem]">
        Feature matrix per plan (per-driver model).
        <span class="lg:hidden"> Scroll sideways to compare plans &rarr;</span>
      </p>
      <div class="mt-8 overflow-x-auto rounded-[var(--r)] border border-hair bg-surface">
        <table class="w-full min-w-[760px] border-collapse text-[0.93rem]">
          <thead>
            <tr class="border-b border-hair-strong text-left">
              <th class="sticky left-0 z-[1] border-r border-hair bg-surface px-5 py-4 font-semibold text-ink">Feature</th>
              {driverPlans.map((p) => (
                <th class="px-5 py-4 text-center font-semibold text-ink">{p.name}</th>
              ))}
            </tr>
          </thead>
          {
            compare.map((g) => (
              <tbody>
                <tr class="border-b border-hair bg-surface-2/60">
                  <th colspan="5" class="px-5 py-3 text-left text-[0.85rem] font-bold text-ink">
                    {g.group}
                  </th>
                </tr>
                {g.rows.map((r) => (
                  <tr class="border-b border-hair last:border-0">
                    <td class="sticky left-0 z-[1] border-r border-hair bg-surface px-5 py-3">{r.label}</td>
                    {r.values.map((v) => (
                      <td class="px-5 py-3 text-center">
                        {v === true ? (
                          <svg class="inline" width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                            <title>Included</title>
                            <path d="M2 7.5L5.5 11L12 3.5" stroke="var(--ok)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        ) : v === false ? (
                          <span class="text-muted" aria-label="Not included">
                            &mdash;
                          </span>
                        ) : (
                          <span class="data text-[0.88rem] text-ink">{v}</span>
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            ))
          }
        </table>
      </div>
    </div>
  </section>

  <FAQ items={billingFaq} title="Billing questions" />

  <CTABanner
    title="Start free, or price it against your fleet."
    note="Trial with every feature of the Growth plan. Talk to sales for volumes beyond the listed tiers."
  />
</Base>

<script is:inline>
  (function () {
    // Toggle state reflected in the URL (?model=order&cycle=monthly) for
    // deep links and E2E (SPEC-05 section 6).
    var modelGroup = document.getElementById('model-toggle');
    var cycleGroup = document.getElementById('cycle-toggle');
    var driver = document.getElementById('plans-driver');
    var order = document.getElementById('plans-order');

    function setRadio(group, attr, value) {
      group.querySelectorAll('button').forEach(function (b) {
        var on = b.dataset[attr] === value;
        b.setAttribute('aria-checked', String(on));
        b.classList.toggle('bg-accent', on);
        b.classList.toggle('text-accent-ink', on);
      });
    }
    function apply(model, cycle, push) {
      setRadio(modelGroup, 'model', model);
      setRadio(cycleGroup, 'cycle', cycle);
      driver.classList.toggle('hidden', model !== 'driver');
      order.classList.toggle('hidden', model !== 'order');
      cycleGroup.style.visibility = model === 'order' ? 'hidden' : 'visible';
      document.querySelectorAll('.price-value').forEach(function (el) {
        var v = cycle === 'annual' ? el.dataset.annual : el.dataset.monthly;
        el.textContent = '£' + v;
      });
      if (push) {
        var url = new URL(location.href);
        url.searchParams.set('model', model);
        url.searchParams.set('cycle', cycle);
        history.replaceState(null, '', url);
      }
    }
    var params = new URLSearchParams(location.search);
    var model = params.get('model') === 'order' ? 'order' : 'driver';
    var cycle = params.get('cycle') === 'monthly' ? 'monthly' : 'annual';
    apply(model, cycle, false);

    modelGroup.addEventListener('click', function (e) {
      var b = e.target.closest('button');
      if (b) {
        model = b.dataset.model;
        apply(model, cycle, true);
      }
    });
    cycleGroup.addEventListener('click', function (e) {
      var b = e.target.closest('button');
      if (b) {
        cycle = b.dataset.cycle;
        apply(model, cycle, true);
      }
    });
  })();
</script>
