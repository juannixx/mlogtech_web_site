---
import Base from '../../layouts/Base.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = new Intl.DateTimeFormat('en-GB', { dateStyle: 'medium' });
---

<Base
  title="Blog | Delivery operations, explained | MLogTech"
  description="Plain-language writing on delivery operations: proof of delivery, route optimisation, last mile cost and transport management."
>
  <section class="section">
    <div class="wrap">
      <h1 class="display max-w-[16ch]">Delivery operations, explained.</h1>
      <p class="lead mt-4">
        No growth hacks, no fluff. The mechanics of running deliveries well, written for the
        people who run them.
      </p>

      {
        posts.length === 0 ? (
          <div class="mt-12 rounded-[var(--r)] border border-hair bg-surface p-10 text-center">
            <p class="text-[1.02rem] text-ink">The first articles are on the way.</p>
            <p class="mt-2 text-muted">
              In the meantime, see the <a class="textlink" href="/features/">product features</a> or
              <a class="textlink" href="/demo/"> book a demo</a>.
            </p>
          </div>
        ) : (
          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="reveal group flex flex-col rounded-[var(--r)] border border-hair bg-surface p-7 transition-transform duration-200 hover:-translate-y-1"
              >
                <span class="text-[0.85rem] font-semibold text-accent-text">
                  {post.data.category}
                </span>
                <h2 class="h3 mt-2">{post.data.title}</h2>
                <p class="mt-3 flex-1 text-[0.95rem]">{post.data.description}</p>
                <span class="mt-5 text-[0.85rem] text-muted">{fmt.format(post.data.pubDate)}</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
  <CTABanner
    title="Put it into practice."
    note="Run a real day of deliveries through MLogTech. Free trial, no card required."
  />
</Base>
