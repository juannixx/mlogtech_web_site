---
import Base from '../../layouts/Base.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = new Intl.DateTimeFormat('en-GB', { dateStyle: 'long' });

// Reading time, computed from the article body (~200 wpm). Factual, not invented.
const words = (post.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(words / 200));

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { '@type': 'Organisation', name: 'MLogTech' },
  publisher: { '@type': 'Organisation', name: 'MLogTech' },
};
---

<Base
  title={`${post.data.title} | MLogTech Blog`}
  description={post.data.description}
  jsonLd={[articleSchema]}
>
  <article class="section">
    <div class="wrap max-w-[720px]">
      <p class="text-[0.9rem] font-semibold text-accent-text">
        <a href="/blog/" class="hover:underline">Blog</a>
        <span aria-hidden="true"> / </span>
        {post.data.category}
      </p>
      <h1 class="display mt-3 text-[clamp(2rem,4vw,2.9rem)]">{post.data.title}</h1>
      <p class="mt-3 text-[0.9rem] text-muted">
        {fmt.format(post.data.pubDate)} <span aria-hidden="true">·</span> {readingMinutes} min read
      </p>
      <div class="prose mt-10">
        <Content />
      </div>
    </div>
  </article>
  <CTABanner
    title="Put it into practice."
    note="Run a real day of deliveries through MLogTech. Free trial, no card required."
  />
</Base>

<style>
  .prose :global(h2) {
    font-size: 1.4rem;
    margin-top: 2.4rem;
  }
  .prose :global(p) {
    margin-top: 1rem;
    font-size: 1.05rem;
    text-wrap: pretty;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-top: 1rem;
    padding-left: 1.3rem;
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }
  .prose :global(li) {
    margin-top: 0.5rem;
  }
  .prose :global(a) {
    color: var(--accent-text);
    font-weight: 600;
  }
  .prose :global(a:hover) {
    text-decoration: underline;
  }
  .prose :global(strong) {
    color: var(--ink);
  }
</style>
