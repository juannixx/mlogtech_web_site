---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';
import { faqGroups } from '../data/faq';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqGroups.flatMap((g) =>
    g.items.map((i) => ({
      '@type': 'Question',
      name: i.q,
      acceptedAnswer: { '@type': 'Answer', text: i.a },
    }))
  ),
};
---

<Base
  title="FAQ | Product, setup, technical and billing questions | MLogTech"
  description="The 20 questions we hear most about MLogTech: what the product does, how to get started, technical details and how billing works."
  jsonLd={[schema]}
>
  <section class="section">
    <div class="wrap max-w-[860px]">
      <h1 class="display">Questions, answered.</h1>
      <p class="lead mt-4">
        The twenty we hear most, grouped. If yours is missing, <a
          class="textlink"
          href="/contact/">ask a person</a
        >.
      </p>

      {
        faqGroups.map((g) => (
          <div class="mt-12">
            <h2 class="h3 reveal">{g.group}</h2>
            <div class="mt-4 divide-y divide-hair border-y border-hair">
              {g.items.map((i) => (
                <details class="group py-1">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-[1.02rem] font-semibold text-ink [&::-webkit-details-marker]:hidden">
                    {i.q}
                    <svg
                      class="shrink-0 transition-transform duration-200 group-open:rotate-45"
                      width="16"
                      height="16"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M8 2v12M2 8h12"
                        stroke="var(--accent-text)"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    </svg>
                  </summary>
                  <p class="pb-5 pr-8 text-body">{i.a}</p>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
  <CTABanner
    title="Question we did not answer?"
    note="A person replies within one working day. Or start the free trial and see for yourself."
  />
</Base>
