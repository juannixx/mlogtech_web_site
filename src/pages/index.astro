---
import Base from '../layouts/Base.astro';
import DashboardMock from '../components/DashboardMock.astro';
import PhoneMock from '../components/PhoneMock.astro';
import RouteMap from '../components/RouteMap.astro';
import TrustStrip from '../components/TrustStrip.astro';
import CTABanner from '../components/CTABanner.astro';
import { SIGNUP_URL, CTA_PRIMARY, CTA_SECONDARY, SITE_NAME } from '../data/site';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: SITE_NAME,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, iOS, Android',
  description:
    'Delivery management software with electronic proof of delivery, live tracking and route optimization.',
};

const pains = [
  {
    title: 'Failed deliveries you find out about tomorrow',
    body: 'A missed drop only surfaces when the customer complains. By then the van is back and the reroute costs double.',
  },
  {
    title: 'Paper PODs that go missing',
    body: 'Signatures live on sheets in glove boxes. Proving a delivery for an invoice dispute means digging through paper.',
  },
  {
    title: '"Where is my order?" calls all day',
    body: 'Without live tracking and notifications, your office becomes a call center for delivery status.',
  },
];

const steps = [
  {
    title: 'Import your orders',
    body: 'Upload a spreadsheet or connect the API. Orders land on the dispatch board with addresses validated.',
  },
  {
    title: 'Optimize the routes',
    body: 'One click builds the day’s routes against vehicles, time windows and capacity. Adjust by drag and drop.',
  },
  {
    title: 'Drivers execute in the app',
    body: 'Each driver gets their route with navigation and order details, online or offline.',
  },
  {
    title: 'Proof closes the loop',
    body: 'Signature, photo and timestamp are captured at the door, and the POD lands on the order instantly, ready to share with the customer.',
  },
];
---

<Base
  title="MLogTech | Delivery management software with electronic proof of delivery"
  description="Plan optimized routes, run deliveries with a driver app, capture electronic proof of delivery and give customers live tracking. Built by MLogTech."
  jsonLd={[softwareSchema]}
>
  <!-- 1. Hero: the "One system." payoff is the dominant beat; the three
       capabilities set it up. Emphasis by size/weight only (no hi-vis on text). -->
  <section class="section pt-12 lg:pt-16">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[1.08fr_1fr]">
      <div class="reveal">
        <h1 class="text-balance">
          <span class="block text-[clamp(1.5rem,2.6vw,2.15rem)] font-semibold leading-tight text-body">
            Proof of delivery, live tracking, optimized routes.
          </span>
          <span class="mt-3 block font-extrabold leading-[0.98] tracking-[-0.03em] text-ink text-[clamp(3.25rem,8vw,5.5rem)]">
            One system.
          </span>
        </h1>
        <p class="lead mt-6 max-w-[46ch]">
          Plan the route, run it through the driver app, prove every drop. One record per order,
          from the depot to the doorstep.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={SIGNUP_URL} class="btn btn-primary">{CTA_PRIMARY}</a>
          <a href="/demo/" class="btn btn-ghost">{CTA_SECONDARY}</a>
        </div>
        <p class="mt-4 text-[0.9rem] text-muted">Free trial. No card required.</p>
      </div>
      <div class="reveal">
        <DashboardMock />
      </div>
    </div>
  </section>

  <!-- 2. Social proof -->
  <TrustStrip />

  <!-- 3. Problem -->
  <section class="section">
    <div class="wrap">
      <h2 class="h2 reveal max-w-[24ch]">The last mile is where the plan falls apart.</h2>
      <div class="mt-10 grid gap-8 md:grid-cols-3">
        {
          pains.map((p) => (
            <div class="reveal border-t-2 border-hair-strong pt-5">
              <h3 class="h3">{p.title}</h3>
              <p class="mt-3 text-[1.02rem]">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Three pillars -->
  <section class="section bg-surface-2">
    <div class="wrap">
      <div class="reveal max-w-[60ch]">
        <h2 class="h2">Plan it. Run it. Prove it.</h2>
        <p class="lead mt-4">
          Planning, execution and proof usually live in separate tools. Here they share one record
          per order.
        </p>
      </div>
      <!-- Bento: the execution tile (driver app + ePOD, the core) is the
           focal navy panel; Plan and Track stack beside it. De-numbered:
           these are parallel capabilities, not an ordered sequence. -->
      <div class="mt-10 grid gap-6 lg:grid-cols-2 lg:grid-rows-2">
        <!-- Deliberate fixed-dark focal tile (navy in both themes), so it
             anchors the bento; literal colors, not theme-swapped tokens. -->
        <a
          href="/solutions/driver-app/"
          class="reveal group flex flex-col justify-between rounded-[var(--r)] border border-white/12 bg-[color:var(--fixed-dark)] p-8 shadow-[var(--shadow-lg)] lg:row-span-2 lg:p-10"
        >
          <div>
            <h3 class="text-[color:var(--fixed-ink)] text-[clamp(1.5rem,2.4vw,2rem)] font-bold leading-tight">
              Execute at the door.
            </h3>
            <p class="mt-4 max-w-[38ch] text-[1.02rem] text-[color:var(--fixed-body)]">
              Drivers run the route in the app: navigation, order details, then signature, photo
              and barcode capture at the door. Proof lands on the order the moment it happens.
            </p>
          </div>
          <span class="mt-8 font-semibold text-accent transition-transform duration-200 group-hover:translate-x-1">
            Driver app and ePOD &rarr;
          </span>
        </a>
        <a
          href="/solutions/route-planning/"
          class="reveal group flex flex-col rounded-[var(--r)] border border-hair bg-surface p-7 transition-transform duration-200 hover:-translate-y-1"
        >
          <h3 class="h3">Plan the day in minutes.</h3>
          <p class="mt-3 flex-1 text-[1.02rem]">
            Import orders and build optimized multi-stop routes, matched to vehicles and shifts.
          </p>
          <span class="textlink mt-5">Route planning</span>
        </a>
        <a
          href="/features/live-tracking/"
          class="reveal group flex flex-col rounded-[var(--r)] border border-hair bg-surface p-7 transition-transform duration-200 hover:-translate-y-1"
        >
          <h3 class="h3">Track it to the door.</h3>
          <p class="mt-3 flex-1 text-[1.02rem]">
            You watch every vehicle live; your customer follows their delivery on a branded page.
          </p>
          <span class="textlink mt-5">Tracking and reports</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. How it works: the route spine. This is the page's structural motif,
       one order followed down the route, the hi-vis line as its backbone. -->
  <section class="section">
    <div class="wrap">
      <h2 class="reveal max-w-[20ch] text-[clamp(2rem,4vw,3.25rem)] font-extrabold leading-[1.03] tracking-[-0.02em]">
        Follow one order down the whole route.
      </h2>
      <p class="lead reveal mt-4">
        Four steps, one record. The same order you import is the one your customer signs for.
      </p>
      <ol class="relative mt-14 grid gap-10 md:grid-cols-4">
        <div
          class="absolute left-[11px] top-[11px] hidden h-[3px] bg-accent md:block"
          style="right: calc((100% - 7.5rem) / 4 - 11px)"
          aria-hidden="true"
        >
        </div>
        {
          steps.map((s, i) => (
            <li class="reveal relative md:pt-12">
              <span
                class="absolute left-0 top-0 hidden h-[22px] w-[22px] items-center justify-center rounded-full border-4 border-bg bg-accent shadow-[0_0_0_1px_var(--accent)] md:flex"
                aria-hidden="true"
              >
                <span class="data text-[0.75rem] font-bold text-accent-ink">{i + 1}</span>
              </span>
              <span class="data text-[0.8rem] text-accent-text md:hidden">Step {i + 1}</span>
              <h3 class="h3 mt-2 md:mt-0">{s.title}</h3>
              <p class="mt-2 max-w-[34ch] text-[0.95rem]">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 6. Feature spotlight: ePOD -->
  <section class="section bg-surface-2" id="epod">
    <div class="wrap grid items-center gap-12 lg:grid-cols-2">
      <div class="reveal order-2 lg:order-1">
        <PhoneMock />
      </div>
      <div class="reveal order-1 lg:order-2">
        <h2 class="h2">Proof of delivery that holds up.</h2>
        <p class="mt-4 text-[1.02rem]">
          Signature, photo and barcode scan captured at the door, stamped with time and location.
          The POD syncs the moment it happens and works offline when the signal does not.
        </p>
        <ul class="mt-6 space-y-3 text-[1.02rem]">
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Electronic signature and photo proof on every drop
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            QR and barcode scanning against the order
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Offline capture with automatic sync
          </li>
        </ul>
        <a href="/features/proof-of-delivery/" class="textlink mt-6 inline-block"
          >More on electronic POD</a
        >
      </div>
    </div>
  </section>

  <!-- 7. Feature spotlight: tracking -->
  <section class="section">
    <div class="wrap grid items-center gap-12 lg:grid-cols-2">
      <div class="reveal">
        <h2 class="h2">Your customer stops calling. They can see the van.</h2>
        <p class="mt-4 text-[1.02rem]">
          Every order gets a live tracking page with your brand on it: position, ETA and status.
          Notifications go out automatically at dispatch, en route and delivered.
        </p>
        <ul class="mt-6 space-y-3 text-[1.02rem]">
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Branded tracking page per delivery
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Live ETA recalculated on the road
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Email and push notifications per status
          </li>
        </ul>
        <a href="/features/live-tracking/" class="textlink mt-6 inline-block"
          >More on live tracking</a
        >
      </div>
      <div class="reveal">
        <RouteMap />
      </div>
    </div>
  </section>

  <!-- 8. Beyond the route: the driver operation a pure router won't run.
       Real differentiators from the product catalogue, shown with two real
       driver-app screens (onboarding + pay). -->
  <section class="section bg-surface-2">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="reveal flex justify-center gap-4">
        <figure class="w-1/2 max-w-[220px]">
          <img
            src="/images/product/app-onboarding.png"
            alt="MLogTech driver app: guided onboarding, step 1 of 8, pick your place"
            width="414"
            height="852"
            loading="lazy"
            class="w-full rounded-[var(--r)] border border-hair shadow-[var(--shadow-lg)]"
          />
          <figcaption class="mt-2 text-center text-[0.8rem] text-muted">Guided onboarding</figcaption>
        </figure>
        <figure class="mt-8 w-1/2 max-w-[220px]">
          <img
            src="/images/product/app-payments.png"
            alt="MLogTech driver app: weekly driver pay with pending and paid statements"
            width="405"
            height="832"
            loading="lazy"
            class="w-full rounded-[var(--r)] border border-hair shadow-[var(--shadow-lg)]"
          />
          <figcaption class="mt-2 text-center text-[0.8rem] text-muted">Driver pay, in the app</figcaption>
        </figure>
      </div>
      <div class="reveal">
        <h2 class="h2 max-w-[20ch]">A pure router stops at the depot gate.</h2>
        <p class="lead mt-4">
          MLogTech also runs the people, compliance and vehicles behind every route, in the same
          system. That is what a routing tool alone will not do.
        </p>
        <div class="mt-8 grid gap-x-8 gap-y-6 sm:grid-cols-2">
          <div>
            <h3 class="text-[1.02rem] font-bold text-ink">Onboarding &amp; compliance</h3>
            <p class="mt-1 text-[0.95rem]">
              An 8-step first run captures documents, right-to-work and a DVLA licence check, with
              training records kept per driver.
            </p>
          </div>
          <div>
            <h3 class="text-[1.02rem] font-bold text-ink">Workforce &amp; pay</h3>
            <p class="mt-1 text-[0.95rem]">
              Schedules turn into driver invoices; the app shows pay as pending, flips it to paid
              on the date, and holds the official payslip.
            </p>
          </div>
          <div>
            <h3 class="text-[1.02rem] font-bold text-ink">Fleet &amp; maintenance</h3>
            <p class="mt-1 text-[0.95rem]">
              A full vehicle registry with inspections, insurance renewals, service reminders and
              odometer history.
            </p>
          </div>
          <div>
            <h3 class="text-[1.02rem] font-bold text-ink">Safety &amp; incidents</h3>
            <p class="mt-1 text-[0.95rem]">
              Drivers log accidents and vehicle damage from the road; offences and quality roll up
              in one view.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Integrations -->
  <section class="section">
    <div class="wrap">
      <div class="reveal max-w-[60ch]">
        <h2 class="h2">Your orders already live somewhere. Bring them in.</h2>
        <p class="lead mt-4">
          Import from spreadsheets today, connect your stack through the API, and use native
          integrations as the catalog rolls out.
        </p>
      </div>
      <!-- One panel, two available-now columns split by a hairline, with the
           rollout note as a footer row. Distinct from the card grids above. -->
      <div class="reveal mt-10 overflow-hidden rounded-[var(--r-lg)] border border-hair bg-surface">
        <div class="grid gap-px bg-hair sm:grid-cols-2">
          <div class="bg-surface p-8">
            <span class="data text-[0.75rem] text-accent-text">Available now</span>
            <h3 class="h3 mt-2">Spreadsheets and CSV</h3>
            <p class="mt-2 text-[0.95rem]">
              Upload the day's orders exactly as they come from your ERP export.
            </p>
          </div>
          <div class="bg-surface p-8">
            <span class="data text-[0.75rem] text-accent-text">Available now</span>
            <h3 class="h3 mt-2">REST API and webhooks</h3>
            <p class="mt-2 text-[0.95rem]">
              Push orders in, get PODs and status events back, keyed to your own IDs.
            </p>
          </div>
        </div>
        <div class="flex flex-wrap items-center justify-between gap-3 border-t border-hair px-8 py-5">
          <p class="text-[0.95rem]">
            Native connectors for e-commerce and ERP platforms are in rollout.
          </p>
          <a class="textlink shrink-0" href="/integrations/">See the integration paths &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. Final CTA -->
  <CTABanner />
</Base>
