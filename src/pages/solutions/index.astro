---
import Base from '../../layouts/Base.astro';
import CTABanner from '../../components/CTABanner.astro';
import { solutions } from '../../data/solutions';

// Lead with the flagship (route planning) as a focal tile that carries a real
// screenshot; the rest fill a rhythmic grid. Breaks the flat identical-card grid.
const FEATURED = 'route-planning';
const featured = solutions.find((s) => s.slug === FEATURED)!;
const rest = solutions.filter((s) => s.slug !== FEATURED);
---

<Base
  title="Solutions | Delivery software by operation type | MLogTech"
  description="Route planning, last mile delivery, driver app, TMS, courier dispatch and vehicle checks: pick the MLogTech solution that matches your operation."
>
  <section class="section">
    <div class="wrap">
      <h1 class="display max-w-[20ch]">One platform, six ways in.</h1>
      <p class="lead mt-4 max-w-[60ch]">
        Every operation enters through a different door: routes, the driver app, compliance.
        They all land on the same system.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <!-- Focal tile: the flagship solution, with the real dispatch board. -->
        <a
          id={featured.slug}
          href={`/solutions/${featured.slug}/`}
          class="reveal group flex flex-col justify-between overflow-hidden rounded-[var(--r)] border border-hair bg-surface transition-transform duration-200 hover:-translate-y-1 md:col-span-2 lg:row-span-2"
        >
          <div class="p-8 lg:p-10">
            <h2 class="text-[clamp(1.4rem,2.4vw,1.9rem)] font-bold leading-tight text-ink">
              {featured.title}
            </h2>
            <p class="mt-3 max-w-[48ch] text-[1.02rem]">
              Turn the day's orders into optimized multi-stop routes in minutes, matched to your
              vehicles, shifts and time windows, then dispatched straight to the driver app.
            </p>
            <span class="textlink mt-5 inline-block">Explore {featured.nav.toLowerCase()}</span>
          </div>
          <img
            src="/images/product/panel-dashboard.jpg"
            alt="MLogTech dispatch board: the day's routes and stops planned across the fleet"
            width="1500"
            height="732"
            loading="lazy"
            class="max-h-[320px] w-full border-t border-hair object-cover object-top"
          />
        </a>

        {
          rest.map((s) => (
            <div
              id={s.slug}
              class="reveal flex flex-col rounded-[var(--r)] border border-hair bg-surface p-7"
            >
              <h2 class="h3">{s.title}</h2>
              <p class="mt-3 flex-1 text-[0.98rem]">{s.short}</p>
              {s.hasPage ? (
                <a href={`/solutions/${s.slug}/`} class="textlink mt-5">
                  Explore {s.nav.toLowerCase()}
                </a>
              ) : (
                <span class="mt-5 text-[0.9rem] text-muted">Dedicated page in production</span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>
  <CTABanner
    title="Not sure which door is yours?"
    note="Start a free trial, or book a walkthrough and we will map it to your operation."
  />
</Base>
