---
import Base from '../../layouts/Base.astro';
import CTABanner from '../../components/CTABanner.astro';
import { featured, webPanel, driverApp } from '../../data/features';

// Lead with ePOD as the focal navy tile (the through-line capability, echoing
// the home), so the grid has a hierarchy instead of nine identical cards.
const LEAD = 'proof-of-delivery';
const lead = featured.find((f) => f.slug === LEAD)!;
const rest = featured.filter((f) => f.slug !== LEAD);
---

<Base
  title="Features | Web panel and driver app | MLogTech"
  description="Everything in the MLogTech delivery platform: route optimisation, electronic proof of delivery, live tracking, notifications, reports and a driver app that works offline."
>
  <section class="section pb-8">
    <div class="wrap">
      <h1 class="display max-w-[22ch]">Everything the route needs, listed.</h1>
      <p class="lead mt-4 max-w-[60ch]">
        The web panel plans and watches the operation; the driver app executes it. These are the
        pieces, with the nine most asked-about first.
      </p>
    </div>
  </section>

  <section class="pb-16">
    <div class="wrap grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <!-- Focal tile: ePOD, the capability the whole system closes on.
           Each card carries a representative photo behind a dark scrim. -->
      <a
        id={lead.slug}
        href={`/features/${lead.slug}/`}
        class="reveal group relative isolate flex min-h-[280px] flex-col justify-end overflow-hidden rounded-[var(--r)] border border-white/12 p-8 shadow-[var(--shadow-lg)] transition-transform duration-200 hover:-translate-y-1 md:col-span-2 lg:row-span-2 lg:p-10"
      >
        <img
          src={lead.image}
          alt=""
          aria-hidden="true"
          loading="lazy"
          class="absolute inset-0 -z-10 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 -z-10 bg-gradient-to-t from-[color:var(--fixed-dark)] via-[color:var(--fixed-dark)]/85 to-[color:var(--fixed-dark)]/40"
        >
        </div>
        <h2 class="text-[clamp(1.4rem,2.4vw,1.9rem)] font-bold leading-tight text-[color:var(--fixed-ink)]">
          {lead.title}
        </h2>
        <p class="mt-4 max-w-[42ch] text-[1.02rem] text-[color:var(--fixed-body)]">
          Signature, photo and barcode captured at the door, stamped with time and location. The
          proof syncs the moment it happens and keeps working when the signal does not.
        </p>
        <span class="mt-6 font-semibold text-accent transition-transform duration-200 group-hover:translate-x-1">
          Explore electronic POD &rarr;
        </span>
      </a>

      {
        rest.map((f) => (
          <a
            id={f.slug}
            href={`/features/${f.slug}/`}
            class="reveal group relative isolate flex min-h-[220px] flex-col justify-end overflow-hidden rounded-[var(--r)] border border-white/12 p-6 shadow-[var(--shadow-lg)] transition-transform duration-200 hover:-translate-y-1"
          >
            <img
              src={f.image}
              alt=""
              aria-hidden="true"
              loading="lazy"
              class="absolute inset-0 -z-10 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 -z-10 bg-gradient-to-t from-[color:var(--fixed-dark)] via-[color:var(--fixed-dark)]/85 to-[color:var(--fixed-dark)]/40" />
            <h2 class="h3 text-[color:var(--fixed-ink)]">{f.title}</h2>
            <p class="mt-2 text-[0.95rem] text-[color:var(--fixed-body)]">{f.short}</p>
            <span class="mt-4 font-semibold text-accent transition-transform duration-200 group-hover:translate-x-1">
              Explore &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section bg-surface-2">
    <div class="wrap grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="h2 reveal">Web panel</h2>
        <div class="reveal mt-6 grid grid-cols-3 gap-3">
          {
            [
              '/images/product/panel-dashboard.jpg',
              '/images/product/panel-tracking.jpg',
              '/images/product/panel-quality.jpg',
            ].map((src) => (
              <img
                src={src}
                alt=""
                aria-hidden="true"
                loading="lazy"
                class="aspect-video w-full rounded-[var(--r)] border border-hair object-cover object-left-top shadow-[var(--shadow-md)]"
              />
            ))
          }
        </div>
        <ul class="mt-8 grid gap-x-8 gap-y-2.5 text-[0.95rem] sm:grid-cols-2">
          {
            webPanel.map((item) => (
              <li class="flex gap-2.5">
                <svg class="mt-1.5 shrink-0" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7.5L5.5 11L12 3.5" stroke="var(--accent-text)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h2 class="h2 reveal">Driver app (iOS and Android)</h2>
        <div class="reveal mt-6 grid grid-cols-4 gap-3">
          {
            [
              '/images/product/app-login.png',
              '/images/product/app-address.png',
              '/images/product/app-onboarding.png',
              '/images/product/app-payments.png',
            ].map((src) => (
              <img
                src={src}
                alt=""
                aria-hidden="true"
                loading="lazy"
                class="aspect-[3/4] w-full rounded-[var(--r)] border border-hair object-cover object-top shadow-[var(--shadow-md)]"
              />
            ))
          }
        </div>
        <ul class="mt-8 grid gap-x-8 gap-y-2.5 text-[0.95rem] sm:grid-cols-2">
          {
            driverApp.map((item) => (
              <li class="flex gap-2.5">
                <svg class="mt-1.5 shrink-0" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7.5L5.5 11L12 3.5" stroke="var(--accent-text)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <CTABanner
    title="The whole platform, on your operation."
    note="Start a free trial, or book a walkthrough on your own data. No card required."
  />
</Base>
